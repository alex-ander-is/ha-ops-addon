#!/bin/sh
set -eu

ZERO_SHA=0000000000000000000000000000000000000000
REMOTE_NAME=${1:-origin}
requires_release_check=0
pushed_tags=""
branch_local_sha=""
branch_remote_sha=""

while read -r local_ref local_sha remote_ref remote_sha
do
  case "$local_ref:$local_sha:$remote_ref" in
    refs/tags/*:*:refs/tags/*)
      tag_name=${local_ref#refs/tags/}
      pushed_tags="$pushed_tags $tag_name"
      ;;
    refs/heads/main:*:refs/heads/main)
      if [ "$local_sha" != "$ZERO_SHA" ]; then
        requires_release_check=1
        branch_local_sha=$local_sha
        branch_remote_sha=$remote_sha
      fi
      ;;
  esac
done

if [ "$requires_release_check" = "1" ]; then
  if [ "$branch_remote_sha" = "$ZERO_SHA" ]; then
    empty_tree=$(git hash-object -t tree /dev/null)
    changed_files=$(git diff --name-only "$empty_tree" "$branch_local_sha")
  else
    changed_files=$(git diff --name-only "$branch_remote_sha" "$branch_local_sha")
  fi

  echo "$changed_files" | grep -qx "ha-ops/config.yaml" || {
    echo "Push rejected: HA Ops changes must bump ha-ops/config.yaml." >&2
    exit 1
  }
  echo "$changed_files" | grep -qx "ha-ops/CHANGELOG.md" || {
    echo "Push rejected: HA Ops changes must update ha-ops/CHANGELOG.md." >&2
    exit 1
  }

  version=$(sed -n 's/^version:[[:space:]]*"\{0,1\}\([^"]*\)"\{0,1\}[[:space:]]*$/\1/p' ha-ops/config.yaml | head -n 1)
  if [ -z "$version" ]; then
    echo "Push rejected: could not read ha-ops/config.yaml version." >&2
    exit 1
  fi

  git rev-parse -q --verify "refs/tags/$version" >/dev/null || {
    echo "Push rejected: missing local tag $version for HA Ops version $version." >&2
    exit 1
  }

  if git ls-remote --exit-code --tags "$REMOTE_NAME" "refs/tags/$version" >/dev/null 2>&1; then
    :
  else
    case " $pushed_tags " in
      *" $version "*)
        ;;
      *)
        echo "Push rejected: tag $version must be pushed with this release." >&2
        exit 1
        ;;
    esac
  fi
fi

echo "Running HA Ops tests before push..."
python3 -m unittest discover -s ha-ops/tests
